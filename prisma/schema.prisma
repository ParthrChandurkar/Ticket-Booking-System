generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())
}

enum Role {
  CUSTOMER
  ORGANISER
  ADMIN
}

model Venue {
  id          String       @id @default(uuid())
  name        String
  address     String
  createdBy   String
  createdAt   DateTime     @default(now())
  seatLayouts SeatLayout[]
}

model SeatLayout {
  id          String     @id @default(uuid())
  venueId     String
  venue       Venue      @relation(fields: [venueId], references: [id])
  rowLabel    String
  seatNumber  Int
  category    String
  showSeats   ShowSeat[]

  @@unique([venueId, rowLabel, seatNumber])
}

model Event {
  id          String   @id @default(uuid())
  organiserId String
  venueId     String
  title       String
  description String
  createdAt   DateTime @default(now())
  shows       Show[]
}

model Show {
  id        String     @id @default(uuid())
  eventId   String
  event     Event      @relation(fields: [eventId], references: [id])
  date      DateTime
  time      String
  showSeats ShowSeat[]
}

model ShowSeat {
  id           String     @id @default(uuid())
  showId       String
  show         Show       @relation(fields: [showId], references: [id])
  seatLayoutId String
  seatLayout   SeatLayout @relation(fields: [seatLayoutId], references: [id])
  status       SeatStatus @default(AVAILABLE)
  heldBy       String?
  heldUntil    DateTime?

  @@unique([showId, seatLayoutId])
}

enum SeatStatus {
  AVAILABLE
  HELD
  BOOKED
}
